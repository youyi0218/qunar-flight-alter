{
  // 携程 cookie 文件路径（可选，不填也可抓取公开机票页）
  "cookie_file": "cookie.json",

  // 携程机票 URL 文件路径；每行一个网页 URL，支持前面带“出发/到达/出发日期”说明文字
  "url_file": "url.txt",

  // 定时服务状态文件
  "state_file": ".flight_monitor_state.json",

  // 价格历史文件
  "history_file": ".flight_monitor_history.json",

  // 当没有机票达到预期价格时，仍推送提醒，并附带最低 3 价机票
  "notify_empty_results": true,

  "browser": {
    // 是否无头运行；服务器环境建议保持 true
    "headless": true,

    // 页面等待超时（毫秒）
    "wait_timeout_ms": 25000,

    // 页面轮询间隔（毫秒）
    "poll_interval_ms": 500,

    // 请求重试次数
    "request_retries": 3,

    // 视口宽度
    "viewport_width": 1280,

    // 视口高度
    "viewport_height": 720,

    // Chromium 路径；Ubuntu 常见为 /usr/bin/chromium，不填则自动探测
    "executable_path": "/usr/bin/chromium",

    // 以下选项用于减少带宽占用
    "block_images": true,
    "block_fonts": true,
    "block_media": true,
    "block_stylesheets": true,
    "block_tracking": true
  },

  "service": {
    // 时区
    "timezone": "Asia/Shanghai",

    // 后台抓取轮询间隔（秒）
    "capture_lead_minutes": 10,

    // 每天定时推送时间
    "schedule_times": [
      "09:00",
      "20:30"
    ],

    // 服务循环最大休眠秒数
    "sleep_cap_seconds": 60,

    // 定时容错秒数
    "schedule_grace_seconds": 300,

    // 历史价格保留天数
    "history_retention_days": 7
  },

  "pushplus": {
    // PushPlus Token
    "token": "请替换为你的 PushPlus Token",

    // 推送渠道
    "channel": "wechat",

    // 推送模板
    "template": "html",

    // 多个行程连续推送时的最小间隔秒数
    "min_interval_seconds": 20,

    // PushPlus 最大重试次数
    "retry_count": 5
  },

  "email": {
    // 是否启用邮件推送
    "enabled": true,

    // 当前支持 resend
    "provider": "resend",

    // Resend API Key
    "api_key": "re_xxxxxxxxxxxxxxxxxxxx",

    // 发件人
    "from": "Flight Monitor <flight-monitor@example.com>",

    // 收件人列表
    "to": [
      "your@email.com"
    ]
  },

  // 可选：按航线覆盖预期价格/启用状态。
  // 会优先按 source_url 匹配；没有 source_url 时，再按 出发城市+到达城市+出发日期 匹配 url.txt 中解析出的航线。
  "routes": [
    {
      // 出发城市
      "departure_city": "武汉",

      // 到达城市
      "arrival_city": "海口",

      // 出发日期，格式：YYYY-MM-DD
      "departure_date": "2026-05-05",

      // 预期价格：只推送价格小于等于该值的机票；填 null 表示不限制
      "expected_price": 800,

      // 是否启用
      "enabled": true
    },
    {
      "departure_city": "海口",
      "arrival_city": "武汉",
      "departure_date": "2026-05-01",
      "expected_price": 900,
      "enabled": true
    }
  ]
}
